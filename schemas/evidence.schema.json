{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://client-ontologies.local/schemas/evidence.schema.json",
  "title": "Evidence sources and references",
  "description": "Schemas for source-registry / evidence_sources entries and for the evidence references that cite them. source_ids are file-local; cross-reference resolution is enforced in scripts/validate_ontology.py.",
  "$defs": {
    "sourceType": {
      "enum": [
        "obsidian_note",
        "local_project_doc",
        "git_repo_file",
        "github_issue",
        "github_pr",
        "linear_issue",
        "client_email_or_message",
        "public_url",
        "api_readonly_snapshot",
        "human_approval_record",
        "user_preference"
      ]
    },
    "source": {
      "type": "object",
      "required": ["id", "type", "description"],
      "properties": {
        "id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "type": {"$ref": "#/$defs/sourceType"},
        "path": {"type": "string"},
        "url": {"type": "string"},
        "identifier": {"type": "string"},
        "description": {"type": "string"}
      },
      "additionalProperties": false,
      "patternProperties": {"^x_": {}}
    },
    "evidenceRef": {
      "type": "object",
      "required": ["source_id"],
      "properties": {
        "source_id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "lines": {"type": "string"},
        "note": {"type": "string"},
        "snapshot_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "ISO-8601 date (YYYY-MM-DD) the cited span was last confirmed against the source."
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:utf8-lf-v1:[0-9a-f]{64}$",
          "description": "Versioned SHA-256 of the cited lines: sha256:utf8-lf-v1:<64 lowercase hex>. utf8-lf-v1 = decode UTF-8, normalize CRLF/CR to LF, select the 1-based inclusive `lines` range(s), join with \\n (no trailing newline), SHA-256 the UTF-8 bytes. New normalization behavior must use a new version tag. Verified by scripts/check_evidence.py."
        }
      },
      "additionalProperties": false,
      "patternProperties": {"^x_": {}}
    },
    "evidenceList": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidenceRef"}
    }
  }
}
