{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://client-ontologies.local/schemas/module.schema.json",
  "title": "Ontology module (kind: ontology_module)",
  "description": "The substance of an ontology: entities, relationships, rules, and optional state machines for one workstream. Cross-reference checks (relationship endpoints, conditional evidence) live in scripts/validate_ontology.py.",
  "$defs": {
    "predicateName": {
      "description": "Controlled relationship predicate vocabulary. Seeded from docs/spec.md §7.3 plus every predicate live in clients/*/modules. Adding a predicate is a deliberate schema PR (see docs/conventions.md). scripts/validate_ontology.py PREDICATE_CONSTRAINTS keys and any relationship `inverse` must be members of this enum; tests/run_predicates.py enforces that sync.",
      "enum": [
        "appears_on",
        "archived_by",
        "contains",
        "creates",
        "creates_or_updates",
        "governed_by",
        "governs",
        "measures",
        "merges_with",
        "must_match",
        "overrides",
        "renders_in",
        "requires_approval_from",
        "sourced_from",
        "stored_in",
        "supports",
        "synchronized_by",
        "targets",
        "uses"
      ]
    },
    "entity": {
      "type": "object",
      "required": ["id", "label", "entity_type", "description", "source_confidence"],
      "properties": {
        "id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "label": {"type": "string"},
        "entity_type": {"enum": ["business_object", "work_product", "content_record", "media_asset", "workflow_artifact", "system_resource", "governance_object", "metric", "brand_object"]},
        "description": {"type": "string"},
        "status": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/status"},
        "source_confidence": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/confidence"},
        "public_facing": {"type": "boolean"},
        "workstreams": {"type": "array", "items": {"type": "string"}},
        "fields": {"type": "object"},
        "evidence": {"$ref": "https://client-ontologies.local/schemas/evidence.schema.json#/$defs/evidenceList"}
      },
      "additionalProperties": false,
      "patternProperties": {"^x_": {}}
    },
    "relationship": {
      "type": "object",
      "required": ["id", "subject", "predicate", "object", "source_confidence"],
      "properties": {
        "id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "subject": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "predicate": {"anyOf": [{"$ref": "#/$defs/predicateName"}, {"type": "string", "pattern": "^x_"}]},
        "object": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "cardinality": {"enum": ["one_to_one", "one_to_many", "many_to_one", "many_to_many", "unknown"]},
        "inverse": {"$ref": "#/$defs/predicateName"},
        "description": {"type": "string"},
        "workstreams": {"type": "array", "items": {"type": "string"}},
        "source_confidence": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/confidence"},
        "evidence": {"$ref": "https://client-ontologies.local/schemas/evidence.schema.json#/$defs/evidenceList"}
      },
      "additionalProperties": false,
      "patternProperties": {"^x_": {}}
    },
    "stateMachine": {
      "type": "object",
      "required": ["id", "entity", "states"],
      "properties": {
        "id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "entity": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "source_confidence": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/confidence"},
        "evidence": {"$ref": "https://client-ontologies.local/schemas/evidence.schema.json#/$defs/evidenceList"},
        "states": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "properties": {
              "public": {"type": "boolean"},
              "next": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false,
      "patternProperties": {"^x_": {}}
    }
  },
  "type": "object",
  "required": ["schema_version", "kind", "id", "title", "client_id", "status", "workstreams", "evidence_sources", "entities", "relationships", "rules"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "kind": {"const": "ontology_module"},
    "id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
    "title": {"type": "string"},
    "client_id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
    "status": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/status"},
    "workstreams": {"type": "array", "items": {"type": "string"}},
    "evidence_sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "https://client-ontologies.local/schemas/evidence.schema.json#/$defs/source"}
    },
    "entities": {"type": "array", "items": {"$ref": "#/$defs/entity"}},
    "relationships": {"type": "array", "items": {"$ref": "#/$defs/relationship"}},
    "rules": {"type": "array", "items": {"$ref": "https://client-ontologies.local/schemas/rule.schema.json#/$defs/rule"}},
    "state_machines": {"type": "array", "items": {"$ref": "#/$defs/stateMachine"}}
  },
  "additionalProperties": false,
  "patternProperties": {"^x_": {}}
}
