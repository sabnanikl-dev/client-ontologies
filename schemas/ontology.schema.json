{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://papi.ai/schemas/ontology.schema.json",
  "title": "Client Operating Ontology v0.1",
  "description": "Generic schema for client, ontology module, and projection files. Deterministic repo validation is implemented in scripts/validate_ontology.py.",
  "oneOf": [
    {"$ref": "#/$defs/client"},
    {"$ref": "#/$defs/module"},
    {"$ref": "#/$defs/projection"}
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
    "status": {"enum": ["draft", "proposed", "active", "approved", "owner_reviewed_internal", "deprecated", "prohibited", "unknown"]},
    "confidence": {"enum": ["verified", "owner_reviewed", "inferred", "draft", "unknown"]},
    "evidenceRef": {
      "type": "object",
      "required": ["source_id"],
      "properties": {
        "source_id": {"$ref": "#/$defs/id"},
        "lines": {"type": "string"},
        "note": {"type": "string"}
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "required": ["id", "type", "description"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"enum": ["obsidian_note", "local_project_doc", "git_repo_file", "github_issue", "github_pr", "linear_issue", "client_email_or_message", "public_url", "api_readonly_snapshot", "human_approval_record", "user_preference"]},
        "path": {"type": "string"},
        "url": {"type": "string"},
        "identifier": {"type": "string"},
        "description": {"type": "string"}
      },
      "additionalProperties": true
    },
    "entity": {
      "type": "object",
      "required": ["id", "label", "entity_type", "description", "source_confidence", "evidence"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "label": {"type": "string"},
        "entity_type": {"enum": ["business_object", "work_product", "content_record", "media_asset", "workflow_artifact", "system_resource", "governance_object", "metric", "brand_object"]},
        "description": {"type": "string"},
        "status": {"$ref": "#/$defs/status"},
        "source_confidence": {"$ref": "#/$defs/confidence"},
        "public_facing": {"type": "boolean"},
        "workstreams": {"type": "array", "items": {"type": "string"}},
        "fields": {"type": "object"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidenceRef"}}
      },
      "additionalProperties": true
    },
    "relationship": {
      "type": "object",
      "required": ["id", "subject", "predicate", "object", "source_confidence", "evidence"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "subject": {"$ref": "#/$defs/id"},
        "predicate": {"type": "string"},
        "object": {"$ref": "#/$defs/id"},
        "source_confidence": {"$ref": "#/$defs/confidence"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidenceRef"}}
      },
      "additionalProperties": true
    },
    "rule": {
      "type": "object",
      "required": ["id", "title", "status", "severity", "rule_type", "statement", "source_confidence", "evidence"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"type": "string"},
        "status": {"$ref": "#/$defs/status"},
        "severity": {"enum": ["info", "warning", "blocking", "approval_required"]},
        "rule_type": {"type": "string"},
        "statement": {"type": "string"},
        "machine_check": {"type": "object"},
        "source_confidence": {"$ref": "#/$defs/confidence"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidenceRef"}}
      },
      "additionalProperties": true
    },
    "client": {
      "type": "object",
      "required": ["schema_version", "kind", "id", "name", "status", "source_registry", "privacy", "workstreams"],
      "properties": {
        "schema_version": {"const": "0.1"},
        "kind": {"const": "client"},
        "id": {"$ref": "#/$defs/id"},
        "name": {"type": "string"},
        "status": {"$ref": "#/$defs/status"},
        "source_registry": {"type": "array", "items": {"$ref": "#/$defs/source"}}
      },
      "additionalProperties": true
    },
    "module": {
      "type": "object",
      "required": ["schema_version", "kind", "id", "title", "client_id", "status", "workstreams", "evidence_sources", "entities", "relationships", "rules"],
      "properties": {
        "schema_version": {"const": "0.1"},
        "kind": {"const": "ontology_module"},
        "id": {"$ref": "#/$defs/id"},
        "client_id": {"$ref": "#/$defs/id"},
        "status": {"$ref": "#/$defs/status"},
        "evidence_sources": {"type": "array", "items": {"$ref": "#/$defs/source"}},
        "entities": {"type": "array", "items": {"$ref": "#/$defs/entity"}},
        "relationships": {"type": "array", "items": {"$ref": "#/$defs/relationship"}},
        "rules": {"type": "array", "items": {"$ref": "#/$defs/rule"}}
      },
      "additionalProperties": true
    },
    "projection": {
      "type": "object",
      "required": ["schema_version", "kind", "id", "client_id", "status", "projection_target", "includes", "evidence_sources"],
      "properties": {
        "schema_version": {"const": "0.1"},
        "kind": {"const": "projection"},
        "id": {"$ref": "#/$defs/id"},
        "client_id": {"$ref": "#/$defs/id"},
        "status": {"$ref": "#/$defs/status"},
        "projection_target": {"type": "object"},
        "includes": {"type": "object"},
        "evidence_sources": {"type": "array", "items": {"$ref": "#/$defs/source"}}
      },
      "additionalProperties": true
    }
  }
}
