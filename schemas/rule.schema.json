{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://client-ontologies.local/schemas/rule.schema.json",
  "title": "Ontology rule",
  "description": "Governance/operating rule carried by an ontology module. Conditional evidence requirements (active/approved/prohibited/verified rules must cite evidence) are enforced in scripts/validate_ontology.py, not here.",
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "title", "status", "severity", "rule_type", "statement", "source_confidence"],
      "properties": {
        "id": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/id"},
        "title": {"type": "string"},
        "status": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/status"},
        "severity": {"enum": ["info", "warning", "blocking", "approval_required"]},
        "rule_type": {"type": "string"},
        "statement": {"type": "string"},
        "machine_check": {
          "description": "Optional executable check for scripts/check_rules.py. Type-discriminated: v1 supports exactly disallowed_terms, required_terms, and regex_policy. Each branch fixes its payload shape (additionalProperties:false, x_-prefixed extensions allowed). Unknown types and malformed payloads fail validation. Future types (approval_required_pattern, status_transition) are intentionally NOT accepted yet — add a new oneOf branch when their gates (#9) and state machines (#10) land.",
          "type": "object",
          "required": ["type"],
          "oneOf": [
            {
              "required": ["type", "disallowed_terms"],
              "properties": {
                "type": {"const": "disallowed_terms"},
                "disallowed_terms": {"type": "array", "minItems": 1, "items": {"type": "string"}}
              },
              "additionalProperties": false,
              "patternProperties": {"^x_": {}}
            },
            {
              "required": ["type", "required_terms"],
              "properties": {
                "type": {"const": "required_terms"},
                "required_terms": {"type": "array", "minItems": 1, "items": {"type": "string"}}
              },
              "additionalProperties": false,
              "patternProperties": {"^x_": {}}
            },
            {
              "required": ["type", "pattern", "policy"],
              "properties": {
                "type": {"const": "regex_policy"},
                "pattern": {"type": "string"},
                "policy": {"enum": ["allow", "deny"]}
              },
              "additionalProperties": false,
              "patternProperties": {"^x_": {}}
            }
          ]
        },
        "source_confidence": {"$ref": "https://client-ontologies.local/schemas/defs.schema.json#/$defs/confidence"},
        "evidence": {"$ref": "https://client-ontologies.local/schemas/evidence.schema.json#/$defs/evidenceList"}
      },
      "additionalProperties": false,
      "patternProperties": {"^x_": {}}
    }
  }
}
